    {
      "cell_type": "code",
      "source": [
        "query = \"\"\"\n",
        "SELECT\n",
        "    strftime('%Y', order_date) AS Year,\n",
        "    strftime('%m', order_date) AS Month,\n",
        "    SUM(amount) AS Total_Revenue,\n",
        "    COUNT(DISTINCT order_id) AS Total_Orders\n",
        "FROM online_sales\n",
        "GROUP BY Year, Month\n",
        "ORDER BY Year, Month\n",
        "\"\"\"\n",
        "\n",
        "sales_analysis = pd.read_sql_query(query, conn)\n",
        "print(sales_analysis)"
