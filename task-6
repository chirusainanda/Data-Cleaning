      "cell_type": "code",
      "source": [
        "import sqlite3\n",
        "import pandas as pd\n",
        "\n",
        "# Create database connection\n",
        "conn = sqlite3.connect('sales_data.db')\n",
        "\n",
        "# Create cursor\n",
        "cursor = conn.cursor()"
      ],
      "metadata": {
        "id": "8x3s4cqOO9-i"
      },
      "execution_count": 1,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "cursor.execute(\"\"\"\n",
        "CREATE TABLE online_sales (\n",
        "    order_id INTEGER,\n",
        "    order_date DATE,\n",
        "    amount REAL,\n",
        "    product_id INTEGER\n",
        ")\n",
        "\"\"\")\n",
        "\n",
        "conn.commit()"
      ],
      "metadata": {
        "id": "8dueT53YSl2h"
      },
      "execution_count": 2,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
